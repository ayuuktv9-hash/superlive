{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the SuperLive platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique ID of the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "bio": { "type": "string", "description": "Short biography of the user." },
        "coins": { "type": "number", "description": "Virtual currency balance." },
        "followersCount": { "type": "number", "description": "Number of followers." },
        "followingCount": { "type": "number", "description": "Number of users being followed." },
        "isLive": { "type": "boolean", "description": "Whether the user is currently streaming." }
      },
      "required": ["uid", "displayName", "coins", "followersCount"]
    },
    "Stream": {
      "title": "Stream",
      "description": "A live stream session.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the stream." },
        "creatorId": { "type": "string", "description": "UID of the user who created the stream." },
        "creatorName": { "type": "string", "description": "Display name of the creator." },
        "creatorPhoto": { "type": "string", "description": "Profile picture of the creator." },
        "title": { "type": "string", "description": "Title of the stream." },
        "viewersCount": { "type": "number", "description": "Number of current viewers." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the stream started." },
        "status": { "type": "string", "enum": ["live", "ended"], "description": "Current status of the stream." }
      },
      "required": ["id", "creatorId", "title", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message or gift notification in a stream.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the message." },
        "streamId": { "type": "string", "description": "ID of the stream this message belongs to." },
        "senderId": { "type": "string", "description": "UID of the sender." },
        "senderName": { "type": "string", "description": "Display name of the sender." },
        "text": { "type": "string", "description": "Content of the message." },
        "type": { "type": "string", "enum": ["text", "gift"], "description": "Type of message." },
        "giftName": { "type": "string", "description": "Name of the gift sent (if type is gift)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["id", "streamId", "senderId", "type", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship between two users.",
      "type": "object",
      "properties": {
        "followerId": { "type": "string", "description": "UID of the user who is following." },
        "followingId": { "type": "string", "description": "UID of the user being followed." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the follow occurred." }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "Heart": {
      "title": "Heart",
      "description": "A like/heart sent during a stream.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who sent the heart." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the heart was sent." }
      },
      "required": ["userId", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "A report filed against a stream.",
      "type": "object",
      "properties": {
        "streamId": { "type": "string", "description": "ID of the stream being reported." },
        "streamTitle": { "type": "string", "description": "Title of the stream." },
        "reporterId": { "type": "string", "description": "UID of the user filing the report." },
        "reporterName": { "type": "string", "description": "Name of the user filing the report." },
        "creatorId": { "type": "string", "description": "UID of the stream creator." },
        "creatorName": { "type": "string", "description": "Name of the stream creator." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the report was filed." },
        "status": { "type": "string", "enum": ["pending", "reviewed"], "description": "Current status of the report." }
      },
      "required": ["streamId", "reporterId", "createdAt", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Follow relationships."
    },
    "/streams/{streamId}": {
      "schema": "Stream",
      "description": "Stream session data."
    },
    "/streams/{streamId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages for a specific stream."
    },
    "/streams/{streamId}/hearts/{heartId}": {
      "schema": "Heart",
      "description": "Hearts sent during a specific stream."
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Reports filed by users."
    }
  }
}
